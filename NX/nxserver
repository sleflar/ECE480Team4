    ${SEDCOMMAND} -e 's:^'${CFG_NXUSER_HOME}' = .*:'${CFG_NXUSER_HOME}' = \"'"${TMP_NX_HOME}"'\":' "${ret_getConfigFileName}" > "${ret_getConfigFileName}.bkp"
